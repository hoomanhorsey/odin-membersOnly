const pool = require("../pool");

async function createUserQuery(userData) {
  // eventually here you would use your SQL or query code

  console.log(userData);
  console.log("Calling createUserQuery", userData);
  try {
    const { rows } = await pool.query(
      "INSERT INTO users (firstName, lastName, email, password) VALUES ($1, $2, $3, $4) RETURNING *",
      [
        userData.firstName,
        userData.lastName,
        userData.email,
        userData.password,
      ],
    );
    console.log("from inside query", rows[0]);
    return rows[0];
  } catch (err) {
    err.context = { function: "createUserQuery", input: userData };
    throw err;
  }
}

async function addMemberQuery(email) {
  console.log("update status of member " + email);

  const { rows } = await pool.query(
    `UPDATE users SET membershipstatus = TRUE WHERE email = $1 RETURNING *`,
    [email],
  );

  return rows;
}

// Export it
module.exports = {
  createUserQuery,
  addMemberQuery,
};
