const pool = require("../pool");

async function getAllMsgsQuery() {
  const { rows } = await pool.query(`SELECT
      messages.id,
      messages.messageTitle,
      messages.messageText,
      messages.timeCreated,
      users.firstname, 
      users.lastname
    FROM messages 
    JOIN users ON messages.user_id = users.id`);
  return rows;
}

async function getAllMsgsQueryLoggedOut() {
  const { rows } = await pool.query(
    `SELECT
      messages.id,
      messages.messageTitle,
      messages.messageText
    FROM messages
      `,
  );
  return rows;
}

async function postNewMessageQuery(
  user_id,

  messagetitle,
  messagetext,
) {
  console.log(user_id, messagetitle, messagetext);

  await pool.query(
    `INSERT INTO messages
    (user_id, messagetitle, messagetext) VALUES ($1, $2, $3)`,
    [user_id, messagetitle, messagetext],
  );
}

async function deleteMessageQuery(user_id) {
  await pool.query(`DELETE FROM messages WHERE messages.id = $1`, [user_id]);
}
// Export it
module.exports = {
  getAllMsgsQuery,
  getAllMsgsQueryLoggedOut,
  postNewMessageQuery,
  deleteMessageQuery,
};
